generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum OperatorStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum UserRole {
  SUPER_ADMIN
  OPERATOR_ADMIN
  BRANCH_OWNER     // Dueño de banca: solo puede VER su(s) banca(s), no operar
  BRANCH_MANAGER
  SUPERVISOR
  CASHIER
}

enum CommissionPeriodType {
  DAILY
  WEEKLY
  MONTHLY
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum DrawStatus {
  SCHEDULED
  OPEN
  CLOSED
  RESULTED
  CANCELLED
}

enum Modality {
  QUINIELA
  PALE
  TRIPLETA
  SUPER_PALE
}

enum TicketStatus {
  ACTIVE
  WINNER
  NOT_WINNER
  PAID
  CANCELLED
  EXPIRED
  EXPIRED_PAID
}

enum CashSessionStatus {
  OPEN
  PENDING_CLOSE
  CLOSED
  DISCREPANCY
  APPROVED
}

enum TransactionType {
  SALE
  PRIZE_PAYMENT
  TICKET_CANCEL
  COMMISSION
  CASH_OPEN
  CASH_CLOSE
  ADJUSTMENT
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum PayoutTableStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

enum BetEvalStatus {
  PENDING
  WON
  LOST
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TICKET_CREATE
  TICKET_CANCEL
  TICKET_REPRINT
  PAYMENT_PROCESS
  PAYMENT_AUTHORIZE
  RESULT_PUBLISH
  RESULT_CONFIRM
  RESULT_REPROCESS
  PAYOUT_TABLE_CREATE
  PAYOUT_TABLE_APPROVE
  PAYOUT_TABLE_REJECT
  LIMIT_CREATE
  LIMIT_UPDATE
  LIMIT_DELETE
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  BRANCH_CREATE
  BRANCH_UPDATE
  BRANCH_SUSPEND
  CASH_OPEN
  CASH_CLOSE
  CASH_DISCREPANCY_APPROVE
  SETTING_CHANGE
  PRIZE_CALCULATE
  OPERATOR_CREATE
  OPERATOR_SUSPEND
}

// ─────────────────────────────────────────────────────────────────────────────
// OPERATOR (empresa operadora — reemplaza Tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Operator {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  rncOrId      String?
  contactEmail String
  contactPhone String?
  status       OperatorStatus @default(ACTIVE)
  trialEndsAt  DateTime?
  logoUrl      String?
  primaryColor String?
  createdAt    DateTime       @default(now())

  branches              Branch[]
  users                 User[]
  payoutTables          PayoutTable[]
  betLimits             BetLimit[]
  financialTransactions FinancialTransaction[]
  draws                 Draw[]
  settings              OperatorSetting[]
  commissionConfigs     CommissionConfig[]
  commissionStatements  CommissionStatement[]
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCH (banca física individual)
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id         String       @id @default(uuid())
  operatorId String
  name       String
  code       String
  address    String?
  phone      String?
  status     BranchStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  operator              Operator               @relation(fields: [operatorId], references: [id])
  users                 User[]
  tickets               Ticket[]
  cashSessions          CashSession[]
  financialTransactions FinancialTransaction[]
  betLimits             BetLimit[]
  settings              BranchSetting[]
  payoutTables          PayoutTable[]
  commissionConfigs     CommissionConfig[]
  commissionStatements  CommissionStatement[]

  @@unique([operatorId, code])
  @@index([operatorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  operatorId           String
  branchId             String?
  name                 String
  username             String
  pin                  String
  role                 UserRole
  active               Boolean   @default(true)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  operator             Operator             @relation(fields: [operatorId], references: [id])
  branch               Branch?              @relation(fields: [branchId], references: [id])
  sessions             Session[]
  tickets              Ticket[]
  payments             Payment[]
  auditLogs            AuditLog[]
  results              DrawResult[]
  resultConfirmations  DrawResult[]         @relation("ResultConfirmer")
  openedCashSessions   CashSession[]        @relation("CashOpener")
  closedCashSessions   CashSession[]        @relation("CashCloser")
  approvedCashSessions CashSession[]        @relation("CashApprover")
  cashierSessions      CashSession[]        @relation("CashCashier")
  financialTransactions FinancialTransaction[]
  reprintedTickets     Ticket[]             @relation("TicketReprinter")
  cancelledTickets     Ticket[]             @relation("TicketCanceller")
  payoutTablesCreated   PayoutTable[]        @relation("PayoutCreator")
  payoutTablesApproved  PayoutTable[]        @relation("PayoutApprover")
  commissionsApproved   CommissionStatement[] @relation("CommissionApprover")

  @@unique([operatorId, username])
  @@index([operatorId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  jwtId     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([jwtId])
}

// ─────────────────────────────────────────────────────────────────────────────
// LOTTERY PROVIDERS & DRAWS
// ─────────────────────────────────────────────────────────────────────────────

model LotteryProvider {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  country   String  @default("DO")
  logoUrl   String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  draws              Draw[]
  payoutTableEntries PayoutTableEntry[]
  betLimits          BetLimit[]
  superPaleBetsA     SuperPaleBet[]     @relation("ProviderA")
  superPaleBetsB     SuperPaleBet[]     @relation("ProviderB")
}

model Draw {
  id          String     @id @default(uuid())
  operatorId  String
  providerId  String
  name        String
  scheduledAt DateTime
  openAt      DateTime
  closeAt     DateTime
  timezone    String     @default("America/Santo_Domingo")
  status      DrawStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  operator       Operator         @relation(fields: [operatorId], references: [id])
  provider       LotteryProvider  @relation(fields: [providerId], references: [id])
  result         DrawResult?
  tickets        Ticket[]
  bets           Bet[]
  betLimits      BetLimit[]
  superPaleBetsA SuperPaleBet[]   @relation("DrawA")
  superPaleBetsB SuperPaleBet[]   @relation("DrawB")

  @@index([operatorId, status])
  @@index([operatorId, closeAt])
  @@index([providerId, scheduledAt])
}

model DrawResult {
  id           String   @id @default(uuid())
  drawId       String   @unique
  firstPrize   String
  secondPrize  String?
  thirdPrize   String?
  extraNumbers String[]
  source       String   @default("MANUAL")
  integrityHash String
  publishedBy  String
  publishedAt  DateTime @default(now())
  confirmedBy  String?
  confirmedAt  DateTime?
  status       String   @default("DRAFT")

  draw      Draw @relation(fields: [drawId], references: [id])
  publisher User @relation(fields: [publishedBy], references: [id])
  confirmer User? @relation("ResultConfirmer", fields: [confirmedBy], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYOUT TABLES (catálogo de multiplicadores)
// ─────────────────────────────────────────────────────────────────────────────

model PayoutTable {
  id            String            @id @default(uuid())
  operatorId    String
  branchId      String?
  name          String
  status        PayoutTableStatus @default(DRAFT)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime          @default(now())
  createdBy     String
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionNote String?

  operator Operator          @relation(fields: [operatorId], references: [id])
  branch   Branch?           @relation(fields: [branchId], references: [id])
  creator  User              @relation("PayoutCreator", fields: [createdBy], references: [id])
  approver User?             @relation("PayoutApprover", fields: [approvedBy], references: [id])
  entries  PayoutTableEntry[]

  @@index([operatorId, status, effectiveFrom])
  @@index([branchId, status])
}

model PayoutTableEntry {
  id             String    @id @default(uuid())
  payoutTableId  String
  modality       Modality
  providerId     String?
  multiplier     Decimal   @db.Decimal(8, 4)
  minBetAmount   Decimal   @db.Decimal(10, 2)
  maxBetAmount   Decimal   @db.Decimal(10, 2)

  payoutTable PayoutTable      @relation(fields: [payoutTableId], references: [id])
  provider    LotteryProvider? @relation(fields: [providerId], references: [id])
  bets        Bet[]

  @@unique([payoutTableId, modality, providerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CASH SESSION (apertura/cierre de caja)
// ─────────────────────────────────────────────────────────────────────────────

model CashSession {
  id               String            @id @default(uuid())
  operatorId       String
  branchId         String
  cashierId        String
  openedBy         String
  closedBy         String?
  approvedBy       String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  openingBalance   Decimal           @db.Decimal(10, 2)
  declaredBalance  Decimal?          @db.Decimal(10, 2)
  difference       Decimal?          @db.Decimal(10, 2)
  status           CashSessionStatus @default(OPEN)
  discrepancyNotes String?

  branch   Branch  @relation(fields: [branchId], references: [id])
  cashier  User    @relation("CashCashier", fields: [cashierId], references: [id])
  opener   User    @relation("CashOpener", fields: [openedBy], references: [id])
  closer   User?   @relation("CashCloser", fields: [closedBy], references: [id])
  approver User?   @relation("CashApprover", fields: [approvedBy], references: [id])

  tickets              Ticket[]
  financialTransactions FinancialTransaction[]

  @@index([branchId, status])
  @@index([cashierId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// TICKETS & BETS
// ─────────────────────────────────────────────────────────────────────────────

model Ticket {
  id              String       @id @default(uuid())
  operatorId      String
  branchId        String
  cashierId       String
  drawId          String?
  cashSessionId   String
  ticketNumber    String       @unique
  serialCode      String       @unique
  idempotencyKey  String?      @unique
  status          TicketStatus @default(ACTIVE)
  totalAmount     Decimal      @db.Decimal(10, 2)
  potentialPrize  Decimal      @db.Decimal(10, 2)
  actualPrize     Decimal?     @db.Decimal(10, 2)
  integrityHash   String
  printedAt       DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelReason    String?
  reprintCount    Int          @default(0)
  lastReprintAt   DateTime?
  lastReprintBy   String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())

  branch      Branch      @relation(fields: [branchId], references: [id])
  cashier     User        @relation(fields: [cashierId], references: [id])
  draw        Draw?       @relation(fields: [drawId], references: [id])
  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
  canceller   User?       @relation("TicketCanceller", fields: [cancelledBy], references: [id])
  reprinter   User?       @relation("TicketReprinter", fields: [lastReprintBy], references: [id])

  bets              Bet[]
  superPaleBet      SuperPaleBet?
  payment           Payment?
  integrityLogs     TicketIntegrityLog[]

  @@index([operatorId, branchId, drawId, status])
  @@index([cashSessionId])
  @@index([serialCode])
  @@index([ticketNumber])
  @@index([operatorId, status, createdAt])
}

model Bet {
  id                 String    @id @default(uuid())
  ticketId           String
  drawId             String
  modality           Modality
  numbers            String[]
  amount             Decimal   @db.Decimal(10, 2)
  multiplier         Decimal   @db.Decimal(8, 4)
  potentialPrize     Decimal   @db.Decimal(10, 2)
  payoutTableEntryId String?
  isWinner           Boolean?
  prizeAmount        Decimal?  @db.Decimal(10, 2)

  ticket           Ticket            @relation(fields: [ticketId], references: [id])
  draw             Draw              @relation(fields: [drawId], references: [id])
  payoutTableEntry PayoutTableEntry? @relation(fields: [payoutTableEntryId], references: [id])

  @@index([ticketId])
  @@index([drawId, modality])
}

// Relation needed between Bet and PayoutTableEntry
// Already added payoutTableEntryId above; add reverse relation:
// In PayoutTableEntry add: bets Bet[]

model SuperPaleBet {
  id             String        @id @default(uuid())
  ticketId       String        @unique
  drawIdA        String
  providerIdA    String
  numberA        String
  drawIdB        String
  providerIdB    String
  numberB        String
  amount         Decimal       @db.Decimal(10, 2)
  multiplier     Decimal       @db.Decimal(8, 4)
  potentialPrize Decimal       @db.Decimal(10, 2)
  statusA        BetEvalStatus @default(PENDING)
  statusB        BetEvalStatus @default(PENDING)
  isWinner       Boolean?
  prizeAmount    Decimal?      @db.Decimal(10, 2)
  evaluatedAt    DateTime?

  ticket    Ticket          @relation(fields: [ticketId], references: [id])
  drawA     Draw            @relation("DrawA", fields: [drawIdA], references: [id])
  drawB     Draw            @relation("DrawB", fields: [drawIdB], references: [id])
  providerA LotteryProvider @relation("ProviderA", fields: [providerIdA], references: [id])
  providerB LotteryProvider @relation("ProviderB", fields: [providerIdB], references: [id])

  @@index([drawIdA, statusA])
  @@index([drawIdB, statusB])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(uuid())
  ticketId      String   @unique
  operatorId    String
  branchId      String
  cashSessionId String?
  amount        Decimal  @db.Decimal(10, 2)
  paidBy        String
  paidAt        DateTime @default(now())
  requiresAuth  Boolean  @default(false)
  authorizedBy  String?
  notes         String?

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  cashier  User   @relation(fields: [paidBy], references: [id])

  @@index([operatorId, branchId])
  @@index([paidAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// FINANCIAL LEDGER (append-only)
// ─────────────────────────────────────────────────────────────────────────────

model FinancialTransaction {
  id             String               @id @default(uuid())
  operatorId     String
  branchId       String
  cashSessionId  String?
  type           TransactionType
  direction      TransactionDirection
  amount         Decimal              @db.Decimal(10, 2)
  runningBalance Decimal              @db.Decimal(12, 2)
  referenceType  String?
  referenceId    String?
  description    String?
  reversalOf     String?
  reversedBy     String?
  createdAt      DateTime             @default(now())
  createdById    String

  operator     Operator    @relation(fields: [operatorId], references: [id])
  branch       Branch      @relation(fields: [branchId], references: [id])
  cashSession  CashSession? @relation(fields: [cashSessionId], references: [id])
  createdBy    User        @relation(fields: [createdById], references: [id])

  @@index([branchId, createdAt])
  @@index([cashSessionId])
  @@index([referenceType, referenceId])
  @@index([operatorId, type, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// BET LIMITS
// ─────────────────────────────────────────────────────────────────────────────

model BetLimit {
  id                String    @id @default(uuid())
  operatorId        String
  branchId          String?
  drawId            String?
  providerId        String?
  modality          Modality?
  number            String?
  maxAmount         Decimal   @db.Decimal(10, 2)
  currentAmount     Decimal   @db.Decimal(10, 2) @default(0)
  warningThreshold  Decimal?  @db.Decimal(3, 2)
  blocked           Boolean   @default(false)
  priority          Int       @default(0)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  operator  Operator         @relation(fields: [operatorId], references: [id])
  branch    Branch?          @relation(fields: [branchId], references: [id])
  draw      Draw?            @relation(fields: [drawId], references: [id])
  provider  LotteryProvider? @relation(fields: [providerId], references: [id])

  @@index([operatorId, branchId, providerId, modality, number])
  @@index([drawId, modality, number])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT & INTEGRITY (append-only)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  operatorId String
  userId     String
  action     AuditAction
  entity     String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([operatorId, action])
  @@index([operatorId, entity, entityId])
  @@index([operatorId, createdAt])
}

model TicketIntegrityLog {
  id          String   @id @default(uuid())
  ticketId    String
  action      String
  hashValid   Boolean
  result      String
  performedBy String
  ip          String?
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────────────────────────

model OperatorSetting {
  id         String   @id @default(uuid())
  operatorId String
  key        String
  value      String
  updatedAt  DateTime @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])

  @@unique([operatorId, key])
}

model BranchSetting {
  id        String   @id @default(uuid())
  branchId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, key])
}

// ─────────────────────────────────────────────────────────────────────────────
// TICKET SEQUENCE (secuencia atómica de número de ticket por banca)
// ─────────────────────────────────────────────────────────────────────────────

model TicketSequence {
  branchId     String @id
  lastSequence Int    @default(0)
}

// ─────────────────────────────────────────────────────────────────────────────
// COMISIONES
// ─────────────────────────────────────────────────────────────────────────────

model CommissionConfig {
  id           String               @id @default(uuid())
  operatorId   String
  branchId     String?              // null = aplica a todo el operador
  rate         Decimal              @db.Decimal(5, 4)  // ej: 0.1500 = 15%
  periodType   CommissionPeriodType @default(MONTHLY)
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  operator     Operator   @relation(fields: [operatorId], references: [id])
  branch       Branch?    @relation(fields: [branchId], references: [id])
  statements   CommissionStatement[]

  @@unique([operatorId, branchId])
  @@index([operatorId])
}

model CommissionStatement {
  id                String            @id @default(uuid())
  operatorId        String
  branchId          String
  configId          String
  periodStart       DateTime
  periodEnd         DateTime
  grossSales        Decimal           @db.Decimal(12, 2)
  cancellations     Decimal           @db.Decimal(12, 2)
  prizesPaid        Decimal           @db.Decimal(12, 2)
  netRevenue        Decimal           @db.Decimal(12, 2)
  commissionRate    Decimal           @db.Decimal(5, 4)
  commissionAmount  Decimal           @db.Decimal(12, 2)
  status            CommissionStatus  @default(PENDING)
  approvedBy        String?
  approvedAt        DateTime?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime          @default(now())

  operator    Operator            @relation(fields: [operatorId], references: [id])
  branch      Branch              @relation(fields: [branchId], references: [id])
  config      CommissionConfig    @relation(fields: [configId], references: [id])
  approver    User?               @relation("CommissionApprover", fields: [approvedBy], references: [id])

  @@index([operatorId, branchId, periodStart])
  @@index([status])
}
