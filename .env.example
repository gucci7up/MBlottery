# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://banca_user:banca_pass@localhost:5432/sistema_banca
POSTGRES_USER=banca_user
POSTGRES_PASSWORD=banca_pass
POSTGRES_DB=sistema_banca

# ─── PGBOUNCER ─────────────────────────────────────────────────────────────────
PGBOUNCER_DATABASE_URL=postgresql://banca_user:banca_pass@pgbouncer:5432/sistema_banca

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# ─── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Clave HMAC para firma de tickets (mín. 64 caracteres)
TICKET_SIGNING_KEY=change-this-to-a-very-long-random-key-for-ticket-hmac-signing

# ─── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── RESULTADOS AUTOMÁTICOS ────────────────────────────────────────────────────
# false = solo ingreso manual; true = usar adapters automáticos (si están configurados)
AUTO_RESULTS_ENABLED=false

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
